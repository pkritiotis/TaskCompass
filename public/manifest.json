{
  "manifest_version": 3,
  "name": "Task Compass for Google Tasks",
  "description": "An Eisenhower Matrix companion that helps you prioritize your Google Tasks lists.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "identity", "storage"],
  "host_permissions": ["https://www.googleapis.com/*", "https://oauth2.googleapis.com/*"],
  "oauth2": {
    "client_id": "1053478395405-69qaf52ege0608vmi3gpk36c10ut2gqi.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/tasks"]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Task Compass",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
